{
  "name": "vite-plugin-lowcode-material-vue",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "version": "0.0.2",
  "packageManager": "pnpm@8.10.0",
  "description": "Ali lowcode-engine vue material build plugin for vite.",
  "author": "penjj<https://github.com/penjj>",
  "repository": {
    "type": "git",
    "url": "https://github.com/penjj/vite-plugin-lowcode-material-vue.git"
  },
  "homepage": "https://github.com/penjj/vite-plugin-lowcode-material-vue",
  "keywords": [
    "lowcode-engine",
    "lowcode-engine-vue",
    "material",
    "vite plugin"
  ],
  "files": [
    "global.d.ts",
    "dist",
    "LICENSE"
  ],
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./global": {
      "types": "./global.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepare": "simple-git-hooks && pnpm build",
    "release": "bumpp"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "fs-extra": "^11.3.4",
    "get-port-please": "^3.2.0",
    "ulid": "^2.4.0"
  },
  "devDependencies": {
    "@alilc/lowcode-types": "^1.3.4",
    "@penjj/eslint-config": "^0.3.7",
    "@penjj/prettier-config": "^0.3.7",
    "@penjj/tsconfig": "^0.3.7",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/fs-extra": "^11.0.4",
    "bumpp": "^9.11.1",
    "lint-staged": "^14.0.1",
    "simple-git-hooks": "^2.13.1",
    "tsup": "^7.2.0",
    "typescript": "^5.9.3",
    "vite": "^4.5.14",
    "vue-commitlint": "^0.1.0"
  },
  "eslintConfig": {
    "extends": "@penjj",
    "rules": {
      "vue/max-attributes-per-line": "off"
    }
  },
  "prettier": "@penjj/prettier-config",
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "commit-msg": "pnpm vue-commitlint"
  },
  "lint-staged": {
    "*.ts": "eslint --fix",
    "*.{yaml,yml,json,md}": "prettier --write"
  }
}
